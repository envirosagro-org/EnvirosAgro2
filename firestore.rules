rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} { 
      allow read, write: if false; 
    }

    // Phase 3: Primitives
    function isValidId(id) { 
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    
    // User/Steward validation blueprint
    function isValidSteward(data) {
      return data.keys().hasAll(['esin', 'name', 'email', 'role']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100;
    }

    // Project validation blueprint
    function isValidProject(data) {
      return data.keys().hasAll(['id', 'name', 'totalCapital', 'adminEsin']) &&
             data.name is string && data.name.size() <= 200 &&
             data.totalCapital is number;
    }

    // Signal validation blueprint
    function isValidSignal(data) {
      return data.keys().hasAll(['id', 'type', 'title', 'timestamp', 'priority']) &&
             data.id is string && data.id.size() <= 128 &&
             data.type is string && data.type.size() <= 64 &&
             data.title is string && data.title.size() <= 200 &&
             data.timestamp is string &&
             data.priority in ['low', 'medium', 'high', 'critical'];
    }

    // Fleet validation blueprint
    function isValidFleetNode(data) {
      return data.keys().hasAll(['id', 'name', 'type', 'status']) &&
             data.id is string && data.id.size() <= 128 &&
             data.name is string && data.name.size() <= 100 &&
             data.type is string && data.type.size() <= 100 &&
             data.status in ['ONLINE', 'OFFLINE', 'MAINTENANCE'];
    }

    // Ledger Block validation blueprint
    function isValidLedgerBlock(data) {
      return data.keys().hasAll(['hash', 'previousHash', 'timestamp', 'index']) &&
             data.hash is string && data.hash.size() <= 256 &&
             data.previousHash is string && data.previousHash.size() <= 256 &&
             data.timestamp is string &&
             data.index is number;
    }

    // Transaction validation blueprint
    function isValidTokenTransaction(data) {
      return data.keys().hasAll(['id', 'type', 'farmId', 'details', 'value', 'unit', 'stewardId', 'lastModified']) &&
             data.id is string && data.id.size() <= 128 &&
             data.type is string && data.type.size() <= 64 &&
             data.farmId is string && data.farmId.size() <= 128 &&
             data.details is string && data.details.size() <= 500 &&
             data.value is number &&
             data.unit is string && data.unit.size() <= 16 &&
             data.stewardId is string &&
             data.lastModified is number;
    }

    // Path rules
    match /stewards/{userId} {
      allow read: if isSignedIn();
      allow create: if isVerified() && isValidId(userId) && userId == request.auth.uid && isValidSteward(incoming());
      allow update: if isVerified() && isValidId(userId) && userId == request.auth.uid && isValidSteward(incoming());
    }

    match /projects/{projectId} {
      allow read: if isSignedIn();
      allow create: if isVerified() && isValidId(projectId) && isValidProject(incoming());
      allow update: if isVerified() && isValidId(projectId) && (incoming().adminEsin == existing().adminEsin || incoming().diff(existing()).affectedKeys().hasOnly(['fundedAmount', 'progress', 'status']));
    }

    match /contracts/{contractId} {
      allow read: if isSignedIn();
      allow create: if isVerified() && isValidId(contractId);
      allow update: if isVerified() && (resource.data.investorEsin == request.auth.uid || incoming().diff(existing()).affectedKeys().hasOnly(['status', 'applications']));
    }

    match /orders/{orderId} {
      allow read: if isSignedIn() && (resource.data.customerEsin == request.auth.uid || resource.data.supplierEsin == request.auth.uid);
      allow create: if isVerified() && isValidId(orderId);
      allow update: if isVerified() && (resource.data.customerEsin == request.auth.uid || resource.data.supplierEsin == request.auth.uid);
    }

    match /live_products/{productId} {
      allow read: if isSignedIn();
      allow create: if isVerified() && isValidId(productId);
      allow update: if isVerified() && (resource.data.stewardEsin == request.auth.uid || incoming().diff(existing()).affectedKeys().hasOnly(['votes', 'progress', 'stage']));
    }

    match /media_ledger/{shardId} {
      allow read: if isSignedIn();
      allow create: if isVerified() && isValidId(shardId);
      allow update: if false;
    }

    match /blocks/{blockHash} {
      allow list: if isSignedIn();
      allow get: if isSignedIn() && isValidId(blockHash);
      allow create: if isVerified() && isValidId(blockHash) && isValidLedgerBlock(incoming());
      allow update, delete: if false; // Immutable ledger
    }

    match /transactions/{txId} {
      allow list: if isSignedIn() && resource.data.farmId == request.auth.uid;
      allow get: if isSignedIn() && isValidId(txId) && resource.data.farmId == request.auth.uid;
      allow create: if isVerified() && isValidId(txId) && isValidTokenTransaction(incoming());
      allow update, delete: if false; // Immutable transactions
    }

    match /signals/{signalId} {
      allow read: if isSignedIn();
      allow create: if isVerified() && isValidId(signalId) && isValidSignal(incoming());
      allow update: if isVerified() && isValidId(signalId) && isValidSignal(incoming()) && incoming().diff(existing()).affectedKeys().hasOnly(['read']);
    }

    match /fleet/{nodeId} {
      allow read: if isSignedIn();
      allow create: if isVerified() && isValidId(nodeId) && isValidFleetNode(incoming());
      allow update: if isVerified() && isValidId(nodeId) && isValidFleetNode(incoming()) && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'lastModified']);
    }
  }
}
