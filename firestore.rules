rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() { return request.auth != null; }
    function isOwner(ownerUid) { return isAuthenticated() && request.auth.uid == ownerUid; }
    function isDocOwner() { 
      return isAuthenticated() && 
             (request.auth.uid == resource.data.stewardId || 
              get(/databases/$(database)/documents/stewards/$(request.auth.uid)).data.esin == resource.data.stewardId); 
    }
    
    // Validation
    function isValidSteward(data) {
      return data.stewardId is string && 
             (data.stewardId == request.auth.uid || data.stewardId == data.esin) &&
             data.name is string && data.name.size() > 0 &&
             data.email is string && data.email.size() > 0 &&
             data.esin is string && data.esin.size() > 0;
    }

    function isValidSignal(data) {
      let userEsin = get(/databases/$(database)/documents/stewards/$(request.auth.uid)).data.esin;
      return data.id is string &&
             data.stewardId is string && (data.stewardId == request.auth.uid || data.stewardId == userEsin) &&
             data.type is string &&
             data.title is string && data.title.size() > 0 &&
             data.message is string && data.message.size() > 0 &&
             data.timestamp is string &&
             data.read is bool;
    }

    function isValidMachineNode(data) {
      let userEsin = get(/databases/$(database)/documents/stewards/$(request.auth.uid)).data.esin;
      return data.id is string &&
             data.stewardId is string && (data.stewardId == request.auth.uid || data.stewardId == userEsin) &&
             data.name is string && data.name.size() > 0 &&
             data.type is string &&
             data.status is string;
    }

    function isValidDevice(data) {
      return data.deviceId is string && data.deviceId.size() > 0 && data.deviceId.size() < 100 &&
             data.ownerUid is string && data.ownerUid == request.auth.uid &&
             data.protocol in ['CAN', 'MQTT', 'HTTP', 'Modbus'] &&
             data.status in ['Registered', 'Active', 'Offline'];
    }

    match /stewards/{stewardId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isOwner(stewardId) && isValidSteward(request.resource.data);
      allow update: if isAuthenticated() && isOwner(stewardId) && isValidSteward(request.resource.data);
    }

    match /signals/{signalId} {
      allow read: if isAuthenticated() && (resource.data.stewardId == request.auth.uid || resource.data.type == 'system');
      allow create: if isAuthenticated() && isValidSignal(request.resource.data);
      allow update: if isAuthenticated() && isDocOwner() && isValidSignal(request.resource.data);
      allow delete: if isAuthenticated() && isDocOwner();
    }

    match /machine_nodes/{nodeId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidMachineNode(request.resource.data);
      allow update: if isAuthenticated() && isDocOwner() && isValidMachineNode(request.resource.data);
      allow delete: if isAuthenticated() && isDocOwner();
    }

    match /auditors/{auditorId} {
      allow read: if isAuthenticated();
      allow write: if false; // Managed via admin console
    }

    match /devices/{deviceId} {
      // Only owner can read their device
      allow read: if isAuthenticated() && isOwner(resource.data.ownerUid);
      // Only authenticated user can create, and must set themselves as owner
      allow create: if isAuthenticated() && isValidDevice(request.resource.data);
      // Only owner can update
      allow update: if isAuthenticated() && isOwner(resource.data.ownerUid) && isValidDevice(request.resource.data);
      
      match /telemetry/{telemetryId} {
        // Only owner can read telemetry
        allow read: if isAuthenticated() && isOwner(get(/databases/$(database)/documents/devices/$(deviceId)).data.ownerUid);
        // Only owner can create telemetry
        allow create: if isAuthenticated() && isOwner(get(/databases/$(database)/documents/devices/$(deviceId)).data.ownerUid);
      }
    }

    match /blocks/{blockId} {
      // Anyone authenticated can read the chain
      allow read: if isAuthenticated();
      // Only authenticated users can create a new block
      // Immutability: deny update and delete
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }

    match /calls/{callId} {
      allow read, create, update: if isAuthenticated();
      match /offerCandidates/{candidateId} {
        allow read, create: if isAuthenticated();
      }
      match /answerCandidates/{candidateId} {
        allow read, create: if isAuthenticated();
      }
    }

    match /broadcasts/{sessionId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      match /segments/{segmentId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated();
      }
      match /comments/{commentId} {
        allow read, create: if isAuthenticated();
      }
    }

    match /telemetry_batches/{batchId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
    }

    match /market_analytics/{analyticsId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    match /market_news/{newsId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    match /plots/{plotId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && 
                    (request.resource.data.stewardId == request.auth.uid || 
                     get(/databases/$(database)/documents/stewards/$(request.auth.uid)).data.esin == request.resource.data.stewardId);
      allow update: if isAuthenticated() && isDocOwner();
      allow delete: if isAuthenticated() && isDocOwner();
    }

    match /ar_anchors/{anchorId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /missions/{missionId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && 
                    (request.resource.data.stewardId == request.auth.uid || 
                     get(/databases/$(database)/documents/stewards/$(request.auth.uid)).data.esin == request.resource.data.stewardId);
      allow update: if isAuthenticated() && isDocOwner();
      allow delete: if isAuthenticated() && isDocOwner();
    }
  }
}
