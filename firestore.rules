rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() { return request.auth != null; }
    function isOwner(ownerUid) { return isAuthenticated() && request.auth.uid == ownerUid; }
    
    // Validation
    function isValidDevice(data) {
      return data.deviceId is string && data.deviceId.size() > 0 && data.deviceId.size() < 100 &&
             data.ownerUid is string && data.ownerUid == request.auth.uid &&
             data.protocol in ['CAN', 'MQTT', 'HTTP'] &&
             data.status in ['Registered', 'Active', 'Offline'];
    }

    match /devices/{deviceId} {
      // Only owner can read their device
      allow read: if isAuthenticated() && isOwner(resource.data.ownerUid);
      // Only authenticated user can create, and must set themselves as owner
      allow create: if isAuthenticated() && isValidDevice(request.resource.data);
      // Only owner can update
      allow update: if isAuthenticated() && isOwner(resource.data.ownerUid) && isValidDevice(request.resource.data);
      
      match /telemetry/{telemetryId} {
        // Only owner can read telemetry
        allow read: if isAuthenticated() && isOwner(get(/databases/$(database)/documents/devices/$(deviceId)).data.ownerUid);
        // Only owner can create telemetry
        allow create: if isAuthenticated() && isOwner(get(/databases/$(database)/documents/devices/$(deviceId)).data.ownerUid);
      }
    }

    match /blocks/{blockId} {
      // Anyone authenticated can read the chain
      allow read: if isAuthenticated();
      // Only authenticated users can create a new block
      // Immutability: deny update and delete
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }

    match /calls/{callId} {
      allow read, create, update: if isAuthenticated();
      match /offerCandidates/{candidateId} {
        allow read, create: if isAuthenticated();
      }
      match /answerCandidates/{candidateId} {
        allow read, create: if isAuthenticated();
      }
    }

    match /broadcasts/{sessionId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      match /segments/{segmentId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated();
      }
      match /comments/{commentId} {
        allow read, create: if isAuthenticated();
      }
    }

    match /telemetry_batches/{batchId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
    }

    match /ar_anchors/{anchorId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }
  }
}
