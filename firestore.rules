rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} { 
      allow read, write: if false; 
    }

    // Phase 3: Primitives
    function isValidId(id) { 
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    
    // User/Steward validation blueprint
    function isValidSteward(data) {
      return data.keys().hasAll(['esin', 'name', 'email', 'role']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100;
    }

    // Project validation blueprint
    function isValidProject(data) {
      return data.keys().hasAll(['id', 'name', 'totalCapital', 'adminEsin']) &&
             data.name is string && data.name.size() <= 200 &&
             data.totalCapital is number;
    }

    // Signal validation blueprint
    function isValidSignal(data) {
      return data.keys().hasAll(['id', 'type', 'title', 'timestamp', 'priority']) &&
             data.id is string && data.id.size() <= 128 &&
             data.type is string && data.type.size() <= 64 &&
             data.title is string && data.title.size() <= 200 &&
             data.timestamp is string &&
             data.priority in ['low', 'medium', 'high', 'critical'];
    }

    // Machine node validation blueprint
    function isValidMachineNode(data) {
      return data.keys().hasAll(['id', 'name', 'type', 'status']) &&
             data.id is string && data.id.size() <= 128 &&
             data.name is string && data.name.size() <= 100 &&
             data.type is string && data.type.size() <= 100 &&
             data.status in ['ONLINE', 'OFFLINE', 'MAINTENANCE'];
    }

    // MRV Job validation blueprint
    function isValidMRVJob(data) {
      return data.keys().hasAll(['assetId', 'status', 'createdAt']) &&
             data.assetId is string && data.assetId.size() <= 128 &&
             data.status is string && data.status.size() <= 64;
    }

    // Auditor validation blueprint
    function isValidAuditor(data) {
      return data.keys().hasAll(['email']) &&
             data.email is string && data.email.size() <= 200;
    }

    // WebRTC Call validation blueprint
    function isValidWebRTCCall(data) {
      return data.keys().hasAll(['id', 'callerId', 'calleeId', 'status']) &&
             data.id is string && data.id.size() <= 128 &&
             data.callerId is string && data.callerId.size() <= 128 &&
             data.calleeId is string && data.calleeId.size() <= 128 &&
             data.status in ['INITIATED', 'ESTABLISHED', 'ENDED'];
    }

    // Broadcast validation blueprint
    function isValidBroadcast(data) {
      return data.keys().hasAll(['id', 'hostId', 'status']) &&
             data.id is string && data.id.size() <= 128 &&
             data.hostId is string && data.hostId.size() <= 128 &&
             data.status in ['LIVE', 'FINISHED'];
    }

    // AR Anchor validation blueprint
    function isValidARAnchor(data) {
      return data.keys().hasAll(['id', 'stewardId']) &&
             data.id is string && data.id.size() <= 128 &&
             data.stewardId is string && data.stewardId.size() <= 128;
    }

    // IoT Reading validation blueprint
    function isValidDroneTelemetry(data) {
      return data.keys().hasAll(['id', 'droneId', 'timestamp']) &&
             data.id is string && data.id.size() <= 128 &&
             data.droneId is string && data.droneId.size() <= 128 &&
             data.timestamp is string;
    }

    // LedgerBlock validation blueprint
    function isValidLedgerBlock(data) {
      return data.keys().hasAll(['hash', 'previousHash', 'timestamp', 'index']) &&
             data.hash is string && data.hash.size() <= 128 &&
             data.previousHash is string && data.previousHash.size() <= 128 &&
             data.timestamp is string &&
             data.index is number;
    }

    // TokenTransaction validation blueprint
    function isValidTokenTransaction(data) {
      return data.keys().hasAll(['id', 'type', 'farmId', 'details', 'value', 'unit']) &&
             data.id is string && data.id.size() <= 128 &&
             data.type is string && data.type.size() <= 64 &&
             data.farmId is string && data.farmId.size() <= 128 &&
             data.details is string && data.details.size() <= 200 &&
             data.value is number &&
             data.unit is string && data.unit.size() <= 32;
    }

    // Path rules
    match /stewards/{userId} {
      allow read: if isSignedIn();
      allow create: if isVerified() && isValidId(userId) && userId == request.auth.uid && isValidSteward(incoming());
      allow update: if isVerified() && isValidId(userId) && userId == request.auth.uid && isValidSteward(incoming());
    }

    match /projects/{projectId} {
      allow read: if isSignedIn();
      allow create: if isVerified() && isValidId(projectId) && isValidProject(incoming());
      allow update: if isVerified() && isValidId(projectId) && isValidProject(incoming()) && (incoming().adminEsin == existing().adminEsin || incoming().diff(existing()).affectedKeys().hasOnly(['fundedAmount', 'progress', 'status']));
    }

    match /contracts/{contractId} {
      allow read: if isSignedIn();
      allow create: if isVerified() && isValidId(contractId);
      allow update: if isVerified() && isValidId(contractId) && (resource.data.investorEsin == request.auth.uid || incoming().diff(existing()).affectedKeys().hasOnly(['status', 'applications']));
    }

    match /orders/{orderId} {
      allow list: if isSignedIn() && (resource.data.stewardId == request.auth.uid || resource.data.customerEsin == request.auth.uid || resource.data.supplierEsin == request.auth.uid);
      allow get: if isSignedIn() && isValidId(orderId) && (resource.data.stewardId == request.auth.uid || resource.data.customerEsin == request.auth.uid || resource.data.supplierEsin == request.auth.uid);
      allow create: if isVerified() && isValidId(orderId);
      allow update: if isVerified() && isValidId(orderId) && (resource.data.stewardId == request.auth.uid || resource.data.customerEsin == request.auth.uid || resource.data.supplierEsin == request.auth.uid);
    }

    match /products/{productId} {
      allow read: if isSignedIn();
      allow create: if isVerified() && isValidId(productId);
      allow update: if isVerified() && isValidId(productId);
    }

    match /live_products/{productId} {
      allow read: if isSignedIn();
      allow create: if isVerified() && isValidId(productId);
      allow update: if isVerified() && isValidId(productId) && (resource.data.stewardEsin == request.auth.uid || incoming().diff(existing()).affectedKeys().hasOnly(['votes', 'progress', 'stage']));
    }

    match /media_ledger/{shardId} {
      allow read: if isSignedIn();
      allow create: if isVerified() && isValidId(shardId);
      allow update: if false;
    }

    match /blocks/{blockHash} {
      allow list: if isSignedIn();
      allow get: if isSignedIn() && isValidId(blockHash);
      allow create: if isVerified() && isValidId(blockHash) && isValidLedgerBlock(incoming());
      allow update, delete: if false; // Immutable ledger
    }

    match /transactions/{txId} {
      allow list: if isSignedIn() && (resource.data.stewardId == request.auth.uid || resource.data.farmId == request.auth.uid);
      allow get: if isSignedIn() && isValidId(txId) && (resource.data.stewardId == request.auth.uid || resource.data.farmId == request.auth.uid);
      allow create: if isVerified() && isValidId(txId) && isValidTokenTransaction(incoming());
      allow update, delete: if false; // Immutable transactions
    }

    match /signals/{signalId} {
      allow read: if isSignedIn() && resource.data.stewardId == request.auth.uid;
      allow create: if isVerified() && isValidId(signalId) && isValidSignal(incoming());
      allow update: if isVerified() && isValidId(signalId) && isValidSignal(incoming()) && incoming().diff(existing()).affectedKeys().hasOnly(['read']);
    }

    match /machine_nodes/{nodeId} {
      allow read: if isSignedIn();
      allow create: if isVerified() && isValidId(nodeId) && isValidMachineNode(incoming());
      allow update: if isVerified() && isValidId(nodeId) && isValidMachineNode(incoming()) && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'lastModified']);
    }

    match /mrv_jobs/{jobId} {
        allow read: if isSignedIn() && resource.data.stewardId == request.auth.uid;
        allow create: if isVerified() && isValidId(jobId) && isValidMRVJob(incoming());
        allow update: if isVerified() && isValidId(jobId) && isValidMRVJob(incoming()) && incoming().diff(existing()).affectedKeys().hasOnly(['status']);
    }

    match /auditors/{auditorId} {
        allow read: if isSignedIn();
        allow create: if isVerified() && isValidId(auditorId) && isValidAuditor(incoming());
    }

    match /calls/{callId} {
        allow read: if isSignedIn() && (resource.data.callerId == request.auth.uid || resource.data.calleeId == request.auth.uid);
        allow create: if isVerified() && isValidId(callId) && isValidWebRTCCall(incoming());
        allow update: if isVerified() && isValidId(callId) && isValidWebRTCCall(incoming()) && incoming().diff(existing()).affectedKeys().hasOnly(['status']);
    }

    match /broadcasts/{broadcastId} {
        allow read: if isSignedIn();
        allow create: if isVerified() && isValidId(broadcastId) && isValidBroadcast(incoming());
        allow update: if isVerified() && isValidId(broadcastId) && isValidBroadcast(incoming()) && incoming().diff(existing()).affectedKeys().hasOnly(['status']);
    }

    match /ar_anchors/{anchorId} {
        allow read: if isSignedIn() && resource.data.stewardId == request.auth.uid;
        allow create: if isVerified() && isValidId(anchorId) && isValidARAnchor(incoming());
        allow update: if false;
    }

    match /sensor_readings/{readingId} {
        allow read: if isSignedIn();
        allow create: if isVerified() && isValidId(readingId) && isValidDroneTelemetry(incoming());
        allow update: if false;
    }

    // New additions based on missing collections
    match /industrial_units/{unitId} {
      allow list: if isSignedIn() && resource.data.stewardId == request.auth.uid;
      allow get: if isSignedIn() && isValidId(unitId) && resource.data.stewardId == request.auth.uid;
      allow create: if isVerified() && isValidId(unitId);
      allow update: if isVerified() && isValidId(unitId) && resource.data.stewardId == request.auth.uid;
    }

    match /tasks/{taskId} {
      allow list: if isSignedIn() && resource.data.stewardId == request.auth.uid;
      allow get: if isSignedIn() && isValidId(taskId) && resource.data.stewardId == request.auth.uid;
      allow create: if isVerified() && isValidId(taskId);
      allow update: if isVerified() && isValidId(taskId) && resource.data.stewardId == request.auth.uid;
    }

    match /blueprints/{blueprintId} {
      allow list: if isSignedIn() && resource.data.stewardId == request.auth.uid;
      allow get: if isSignedIn() && isValidId(blueprintId) && resource.data.stewardId == request.auth.uid;
      allow create: if isVerified() && isValidId(blueprintId);
      allow update: if isVerified() && isValidId(blueprintId) && resource.data.stewardId == request.auth.uid;
    }

    match /proposals/{proposalId} {
      allow read: if isSignedIn();
      allow create: if isVerified() && isValidId(proposalId);
      allow update: if isVerified() && isValidId(proposalId);
    }

    match /votes/{voteId} {
      allow read: if isSignedIn();
      allow create: if isVerified() && isValidId(voteId);
      allow update: if isVerified() && isValidId(voteId);
    }

    match /carbon_credits/{creditId} {
      allow read: if isSignedIn();
      allow create: if isVerified() && isValidId(creditId);
      allow update: if isVerified() && isValidId(creditId);
    }

    match /mempool/{mempoolId} {
      allow read: if isSignedIn();
      allow create: if isVerified() && isValidId(mempoolId);
      allow update: if isVerified() && isValidId(mempoolId);
    }
  }
}
