rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    match /nodes/{nodeId} {
      allow read, write: if isAuthenticated();
    }

    match /sourced_assets/{assetId} {
      allow create, read, update, delete: if isAuthenticated();
    }

    match /carbon_credits/{creditId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    match /media_ledger/{mediaId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.authorEsin == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.authorEsin == request.auth.uid;
    }
    
    match /books/{bookId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.authorEsin == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.authorEsin == request.auth.uid;
    }

    match /signals/{signalId} {
      allow read, write: if isAuthenticated();
    }

    match /stewards/{stewardId} {
      allow read: if isAuthenticated() && stewardId == request.auth.uid;
      allow create: if isAuthenticated() && stewardId == request.auth.uid;
      allow update: if isAuthenticated() && stewardId == request.auth.uid;
      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}