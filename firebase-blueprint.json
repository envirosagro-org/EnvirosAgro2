{
  "entities": {
    "Steward": {
      "title": "Steward",
      "description": "Represents a user (steward) in the EnvirosAgro network.",
      "type": "object",
      "properties": {
        "stewardId": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "esin": { "type": "string" },
        "role": { "type": "string" },
        "location": { "type": "string" },
        "lastSync": { "type": "number" },
        "completedActions": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["stewardId", "name", "email", "esin", "role"]
    },
    "Signal": {
      "title": "Signal",
      "description": "A network signal or notification dispatched to a steward.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "stewardId": { "type": "string" },
        "type": { "type": "string" },
        "origin": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "read": { "type": "boolean" },
        "priority": { "type": "string" }
      },
      "required": ["id", "stewardId", "type", "title", "message", "timestamp", "read"]
    },
    "MachineNode": {
      "title": "MachineNode",
      "description": "An IIoT machine node registered in the network.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "stewardId": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string" },
        "status": { "type": "string" },
        "lastModified": { "type": "number" }
      },
      "required": ["id", "stewardId", "name", "type", "status"]
    },
    "HardwareDevice": {
      "title": "HardwareDevice",
      "description": "Represents an IIoT hardware device registered in the FarmSwarm network.",
      "type": "object",
      "properties": {
        "deviceId": { "type": "string", "description": "Unique identifier for the hardware." },
        "ownerUid": { "type": "string", "description": "UID of the user who registered the device." },
        "protocol": { "type": "string", "description": "Communication protocol (e.g., CAN, MQTT, Modbus)." },
        "status": { "type": "string", "description": "Current operational status." },
        "registeredAt": { "type": "string", "format": "date-time", "description": "Timestamp of registration." }
      },
      "required": ["deviceId", "ownerUid", "protocol", "status", "registeredAt"]
    },
    "TelemetryData": {
      "title": "TelemetryData",
      "description": "Represents persistent telemetry data stored in Firestore.",
      "type": "object",
      "properties": {
        "deviceId": { "type": "string" },
        "payload": { "type": "string", "description": "Serialized telemetry payload." },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["deviceId", "payload", "timestamp"]
    },
    "BlockchainBlock": {
      "title": "BlockchainBlock",
      "description": "Represents an immutable block in the EnvirosAgro blockchain ledger.",
      "type": "object",
      "properties": {
        "index": { "type": "integer", "description": "The block's position in the chain." },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the block was added." },
        "transactions": { "type": "array", "items": { "type": "object" }, "description": "An array of transaction data." },
        "previousHash": { "type": "string", "description": "The SHA-256 hash of the previous block." },
        "hash": { "type": "string", "description": "The SHA-256 hash of the current block." },
        "validator": { "type": "string", "description": "The node that validated the block." },
        "status": { "type": "string", "enum": ["Confirmed", "Pending"] }
      },
      "required": ["index", "timestamp", "transactions", "previousHash", "hash", "validator", "status"]
    },
    "MarketAnalytics": {
      "title": "MarketAnalytics",
      "description": "Represents market analytics data.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "sales": { "type": "number" }
      },
      "required": ["name", "sales"]
    },
    "MarketNews": {
      "title": "MarketNews",
      "description": "Represents market news items.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "date": { "type": "string" }
      },
      "required": ["title", "date"]
    },
    "Plot": {
      "title": "Plot",
      "description": "Represents a physical plot or shard on the farm.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "stewardId": { "type": "string" },
        "name": { "type": "string" },
        "geometry": { "type": "object", "description": "GeoJSON polygon geometry." },
        "deviceId": { "type": "string", "description": "Associated IIoT device." }
      },
      "required": ["id", "stewardId", "name", "geometry"]
    }
  },
  "firestore": {
    "/stewards/{stewardId}": {
      "schema": { "$ref": "Steward" },
      "description": "Collection of user profiles (stewards)."
    },
    "/signals/{signalId}": {
      "schema": { "$ref": "Signal" },
      "description": "Collection of network signals and notifications."
    },
    "/machine_nodes/{nodeId}": {
      "schema": { "$ref": "MachineNode" },
      "description": "Collection of registered machine nodes."
    },
    "/devices/{deviceId}": {
      "schema": { "$ref": "HardwareDevice" },
      "description": "Collection of registered hardware devices."
    },
    "/devices/{deviceId}/telemetry/{telemetryId}": {
      "schema": { "$ref": "TelemetryData" },
      "description": "Collection of persistent telemetry records for a device."
    },
    "/blocks/{blockId}": {
      "schema": { "$ref": "BlockchainBlock" },
      "description": "The immutable blockchain ledger."
    },
    "/market_analytics/{analyticsId}": {
      "schema": { "$ref": "MarketAnalytics" },
      "description": "Collection of market analytics data."
    },
    "/market_news/{newsId}": {
      "schema": { "$ref": "MarketNews" },
      "description": "Collection of market news items."
    },
    "/plots/{plotId}": {
      "schema": { "$ref": "Plot" },
      "description": "Collection of physical plots."
    }
  }
}
