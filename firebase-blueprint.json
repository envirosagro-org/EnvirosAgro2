{
  "entities": {
    "User": {
      "title": "Steward User Profile",
      "description": "Represents an EnvirosAgro Steward/User",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "esin": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string" },
        "location": { "type": "string" },
        "wallet": {
          "type": "object",
          "properties": {
            "balance": { "type": "number" },
            "eatBalance": { "type": "number" },
            "stakedEat": { "type": "number" },
            "exchangeRate": { "type": "number" }
          }
        },
        "metrics": {
          "type": "object",
          "properties": {
            "sustainabilityScore": { "type": "number" },
            "agriculturalCodeU": { "type": "number" },
            "timeConstantTau": { "type": "number" }
          }
        },
        "completedActions": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["uid", "esin", "name", "email", "role"]
    },
    "AgroProject": {
      "title": "Agro Project Mission",
      "description": "A funded mission or project",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string" },
        "fundedAmount": { "type": "number" },
        "totalCapital": { "type": "number" },
        "adminEsin": { "type": "string" }
      },
      "required": ["id", "name", "totalCapital", "adminEsin"]
    },
    "AgroContract": {
      "title": "Farming Contract",
      "description": "A contract for farming operations",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "investorEsin": { "type": "string" },
        "category": { "type": "string" },
        "status": { "type": "string" },
        "budget": { "type": "number" }
      },
      "required": ["id", "investorEsin", "budget"]
    },
    "LiveProduct": {
      "title": "Live Farming Asset",
      "description": "Real-time state of a crop or product",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "stewardEsin": { "type": "string" },
        "productType": { "type": "string" },
        "stage": { "type": "string" },
        "progress": { "type": "number" }
      },
      "required": ["id", "stewardEsin", "productType"]
    },
    "AgroOrder": {
      "title": "Marketplace Order",
      "description": "An order of goods or services",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "itemId": { "type": "string" },
        "itemName": { "type": "string" },
        "cost": { "type": "number" },
        "status": { "type": "string" },
        "customerEsin": { "type": "string" },
        "supplierEsin": { "type": "string" }
      },
      "required": ["id", "itemId", "itemName", "cost", "status"]
    },
    "MachineNode": {
      "title": "Agrobot / IoT Machine Node",
      "description": "Represents a single registered machine, bot, or IoT device",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string" },
        "status": { "type": "string", "enum": ["ONLINE", "OFFLINE", "MAINTENANCE"] },
        "stewardId": { "type": "string" },
        "lastModified": { "type": "number" }
      },
      "required": ["id", "name", "type", "status"]
    },
    "VendorProduct": {
      "title": "Marketplace Product",
      "description": "Items listed for sale in the marketplace",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "supplierEsin": { "type": "string" },
        "status": { "type": "string" }
      },
      "required": ["id", "name", "price", "supplierEsin"]
    },
    "TokenTransaction": {
      "title": "EAC Token Transaction",
      "description": "A record of EAC tokens earned or spent",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string" },
        "farmId": { "type": "string" },
        "details": { "type": "string" },
        "value": { "type": "number" },
        "unit": { "type": "string" }
      },
      "required": ["id", "type", "farmId", "details", "value", "unit"]
    },
    "LedgerBlock": {
      "title": "Blockchain Block",
      "description": "A block of transactions on the EnvirosAgro ledger",
      "type": "object",
      "properties": {
        "hash": { "type": "string" },
        "previousHash": { "type": "string" },
        "timestamp": { "type": "string" },
        "validator": { "type": "string" },
        "index": { "type": "number" }
      },
      "required": ["hash", "previousHash", "timestamp", "index"]
    },
    "Signal": {
      "title": "System Signal / Notification",
      "description": "Real-time system pulse or message",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "timestamp": { "type": "string" },
        "read": { "type": "boolean" },
        "priority": { "type": "string" }
      },
      "required": ["id", "type", "title", "timestamp", "priority"]
    },
    "MRVJob": {
      "title": "MRV Analysis Job",
      "description": "A job for background MRV analysis",
      "type": "object",
      "properties": {
        "assetId": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["assetId", "status", "createdAt"]
    },
    "Auditor": {
      "title": "Auditor",
      "description": "Registered auditor",
      "type": "object",
      "properties": {
        "email": { "type": "string" }
      },
      "required": ["email"]
    },
    "WebRTCCall": {
      "title": "WebRTC Call",
      "description": "Session record for WebRTC calls",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "callerId": { "type": "string" },
        "calleeId": { "type": "string" },
        "status": { "type": "string" }
      },
      "required": ["id", "callerId", "calleeId", "status"]
    },
    "BroadcastSession": {
      "title": "Broadcast Session",
      "description": "Live or recorded broadcast session",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "hostId": { "type": "string" },
        "status": { "type": "string" }
      },
      "required": ["id", "hostId", "status"]
    },
    "ARAnchor": {
      "title": "AR Anchor",
      "description": "Spatial mapping anchor",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "stewardId": { "type": "string" }
      },
      "required": ["id", "stewardId"]
    },
    "DroneTelemetry": {
      "title": "Telemetry Reading",
      "description": "Reading from IoT sensors",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "droneId": { "type": "string" },
        "timestamp": { "type": "string" }
      },
      "required": ["id", "droneId", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Holds steward profile records."
    },
    "/stewards/{stewardId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Steward profiles alternative registration path."
    },
    "/fleet/{nodeId}": {
      "schema": { "$ref": "#/entities/MachineNode" },
      "description": "Registry of agrobots and IoT equipment."
    },
    "/machine_nodes/{nodeId}": {
      "schema": { "$ref": "#/entities/MachineNode" },
      "description": "Alternative machine registry."
    },
    "/devices/{deviceId}": {
      "schema": { "$ref": "#/entities/MachineNode" },
      "description": "Device control registry."
    },
    "/products/{productId}": {
      "schema": { "$ref": "#/entities/VendorProduct" },
      "description": "Global marketplace listings."
    },
    "/ledger/{blockHash}": {
      "schema": { "$ref": "#/entities/LedgerBlock" },
      "description": "Verified blocks in the decentralized ledger."
    },
    "/transactions/{txId}": {
      "schema": { "$ref": "#/entities/TokenTransaction" },
      "description": "Ledger transactions for EAC tokens."
    },
    "/signals/{signalId}": {
      "schema": { "$ref": "#/entities/Signal" },
      "description": "System broadcast signals for user notifications."
    },
    "/projects/{projectId}": {
      "schema": { "$ref": "#/entities/AgroProject" },
      "description": "Store all agro project missions."
    },
    "/contracts/{contractId}": {
      "schema": { "$ref": "#/entities/AgroContract" },
      "description": "Store all farming contracts."
    },
    "/orders/{orderId}": {
      "schema": { "$ref": "#/entities/AgroOrder" },
      "description": "Store all user orders."
    },
    "/live_products/{productId}": {
      "schema": { "$ref": "#/entities/LiveProduct" },
      "description": "Real-time production tracking."
    },
    "/mrv_jobs/{jobId}": {
      "schema": { "$ref": "#/entities/MRVJob" },
      "description": "Background MRV jobs."
    },
    "/auditors/{auditorId}": {
      "schema": { "$ref": "#/entities/Auditor" },
      "description": "Registered auditors."
    },
    "/calls/{callId}": {
      "schema": { "$ref": "#/entities/WebRTCCall" },
      "description": "WebRTC call sessions."
    },
    "/broadcasts/{broadcastId}": {
      "schema": { "$ref": "#/entities/BroadcastSession" },
      "description": "Broadcast sessions."
    },
    "/ar_anchors/{anchorId}": {
      "schema": { "$ref": "#/entities/ARAnchor" },
      "description": "AR spatial anchors."
    },
    "/sensor_readings/{readingId}": {
      "schema": { "$ref": "#/entities/DroneTelemetry" },
      "description": "IoT sensor readings."
    }
  }
}

