{
  "entities": {
    "User": {
      "title": "Steward User Profile",
      "description": "Represents an EnvirosAgro Steward/User",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "esin": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string" },
        "wallet": {
          "type": "object",
          "properties": {
            "balance": { "type": "number" },
            "eatBalance": { "type": "number" }
          }
        },
        "metrics": {
          "type": "object",
          "properties": {
            "sustainabilityScore": { "type": "number" },
            "agriculturalCodeU": { "type": "number" }
          }
        }
      },
      "required": ["uid", "esin", "name", "email", "role"]
    },
    "FleetNode": {
      "title": "Agrobot / IoT Fleet Node",
      "description": "Represents a single registered machine or robot",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string" },
        "status": { "type": "string", "enum": ["ONLINE", "OFFLINE", "MAINTENANCE"] },
        "stewardId": { "type": "string" },
        "lastModified": { "type": "number" }
      },
      "required": ["id", "name", "type", "status"]
    },
    "VendorProduct": {
      "title": "Marketplace Product",
      "description": "Items listed for sale in the marketplace",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "supplierEsin": { "type": "string" },
        "status": { "type": "string" }
      },
      "required": ["id", "name", "price", "supplierEsin"]
    },
    "TokenTransaction": {
      "title": "EAC Token Transaction",
      "description": "A record of EAC tokens earned or spent",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string" },
        "farmId": { "type": "string" },
        "details": { "type": "string" },
        "value": { "type": "number" },
        "unit": { "type": "string" }
      },
      "required": ["id", "type", "farmId", "details", "value", "unit"]
    },
    "LedgerBlock": {
      "title": "Blockchain Block",
      "description": "A block of transactions on the EnvirosAgro ledger",
      "type": "object",
      "properties": {
        "hash": { "type": "string" },
        "previousHash": { "type": "string" },
        "timestamp": { "type": "string" },
        "validator": { "type": "string" },
        "index": { "type": "number" }
      },
      "required": ["hash", "previousHash", "timestamp", "index"]
    },
    "Signal": {
      "title": "System Signal / Notification",
      "description": "Real-time system pulse or message",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "timestamp": { "type": "string" },
        "read": { "type": "boolean" },
        "priority": { "type": "string" }
      },
      "required": ["id", "type", "title", "timestamp", "priority"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Holds steward profile records."
    },
    "/fleet/{nodeId}": {
      "schema": { "$ref": "#/entities/FleetNode" },
      "description": "Registry of agrobots and IoT equipment."
    },
    "/products/{productId}": {
      "schema": { "$ref": "#/entities/VendorProduct" },
      "description": "Global marketplace listings."
    },
    "/ledger/{blockHash}": {
      "schema": { "$ref": "#/entities/LedgerBlock" },
      "description": "Verified blocks in the decentralized ledger."
    },
    "/transactions/{txId}": {
      "schema": { "$ref": "#/entities/TokenTransaction" },
      "description": "Ledger transactions for EAC tokens."
    },
    "/signals/{signalId}": {
      "schema": { "$ref": "#/entities/Signal" },
      "description": "System broadcast signals for user notifications."
    }
  }
}
